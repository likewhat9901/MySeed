"use client";

// ─── rpc/ledger.ts ────────────────────────────────────────────────────────────
// ledger 관련 Supabase RPC 함수.
//
// RPC 목록:
//   get_or_create_ledger(p_mem_id)  : 최신 ledger 조회, 없으면 자동 생성
//   get_my_ledgers(p_mem_id)        : 전체 ledger 목록 (최신순)
//   create_ledger(p_mem_id, p_led_name) : 새 ledger 명시적 생성

import { getSupabaseBrowserClient } from "../core/client";

// ── 공통 타입 ─────────────────────────────────────────────────────────────────

export interface LedgerSummary {
  led_id:     string
  led_name:   string
  regist_dt?: string
}

// ── get_or_create_ledger ──────────────────────────────────────────────────────
// RPC: get_or_create_ledger(p_mem_id uuid)
// → TABLE(led_id uuid, led_name text)
//
// 동작:
//   1. mem_id = p_mem_id 인 최신 ledger 조회
//   2. 없으면 led_name = '내 가계부' 로 자동 생성 후 반환
//   RLS: 본인 것만 접근 가능

/**
 * 유저의 최신 ledger를 가져옵니다. 없으면 자동 생성.
 * @returns LedgerSummary 또는 실패 시 null
 */
export async function getOrCreateLedger(memId: string): Promise<LedgerSummary | null> {
  const supabase = getSupabaseBrowserClient()
  const { data, error } = await supabase.rpc('get_or_create_ledger', { p_mem_id: memId })

  if (error || !data) {
    console.error('[rpc/ledger] get_or_create_ledger 실패:', JSON.stringify(error))
    return null
  }

  const row = Array.isArray(data) ? data[0] : data
  return row as LedgerSummary
}

// ── get_my_ledgers ────────────────────────────────────────────────────────────
// RPC: get_my_ledgers(p_mem_id uuid)
// → TABLE(led_id uuid, led_name text, regist_dt timestamptz)
//
// 동작:
//   - mem_id = p_mem_id 인 ledger 목록 반환 (최신순)
//   - ledger 없으면 빈 배열
//   RLS: 본인 것만 조회 가능

/**
 * 유저의 ledger 목록을 가져옵니다.
 * @returns LedgerSummary 배열 (실패 시 빈 배열)
 */
export async function getMyLedgers(memId: string): Promise<LedgerSummary[]> {
  const supabase = getSupabaseBrowserClient()
  const { data, error } = await supabase.rpc('get_my_ledgers', { p_mem_id: memId })

  if (error || !data) {
    console.error('[rpc/ledger] get_my_ledgers 실패:', JSON.stringify(error))
    return []
  }

  return data as LedgerSummary[]
}

// ── create_ledger ─────────────────────────────────────────────────────────────
// RPC: create_ledger(p_mem_id uuid, p_led_name text)
// → TABLE(led_id uuid)
//
// 동작:
//   - 새 ledger를 명시적으로 생성합니다 (이름 지정 가능)
//   - get_or_create_ledger와 달리 항상 새 row를 생성
//   RLS: 본인 것만 생성 가능

/**
 * 새 ledger를 생성합니다.
 * @returns 생성된 led_id 또는 실패 시 null
 */
export async function createLedger(memId: string, name = '내 가계부'): Promise<string | null> {
  const supabase = getSupabaseBrowserClient()
  const { data, error } = await supabase.rpc('create_ledger', {
    p_mem_id:   memId,
    p_led_name: name,
  })

  if (error || !data) {
    console.error('[rpc/ledger] create_ledger 실패:', JSON.stringify(error))
    return null
  }

  const row = Array.isArray(data) ? data[0] : data
  return (row as { led_id: string }).led_id
}
