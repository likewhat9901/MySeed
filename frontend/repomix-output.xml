// ── tb_category ───────────────────────────────────────────────────────────────
// 수입/지출 카테고리.
// TODO: 카테고리 필터 기능 구현 시 필요
export type DbCategory = Pick<Tables<'tb_category'>,
  | 'cate_id'         // PK uuid
