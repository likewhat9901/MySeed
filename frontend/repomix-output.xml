<file path="src/lib/supabase/core/client.ts">
import { createBrowserClient } from "@supabase/ssr";

/**
 * 브라우저(클라이언트 컴포넌트)에서 Supabase를 쓸 때 이 함수를 호출합니다.
 * 매번 새 인스턴스를 만들지 않도록 모듈 레벨에서 싱글톤으로 관리합니다.
 */
let client: ReturnType<typeof createBrowserClient> | null = null;

export function getSupabaseBrowserClient() {
  if (client) return client;

  const url = process.env.NEXT_PUBLIC_SUPABASE_URL;
  const publishableKey = process.env.NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY;

  if (!url || !publishableKey) {
    throw new Error(
      "Supabase 환경변수가 설정되지 않았습니다. " +
        ".env.local에 NEXT_PUBLIC_SUPABASE_URL과 NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY를 추가하세요."
    );
  }

  client = createBrowserClient(url, publishableKey);
  return client;
}
</file>

<file path="src/lib/supabase/core/server.ts">
import { createServerClient } from "@supabase/ssr";
import { cookies } from "next/headers";
import type { NextRequest, NextResponse } from "next/server";

/**
 * middleware 전용: NextRequest/NextResponse 쌍을 받아 서버용 Supabase 클라이언트를 만듭니다.
 * 반환된 클라이언트를 사용한 뒤 response를 그대로 반환해야 Set-Cookie가 적용됩니다.
 */
export function createSupabaseMiddlewareClient(
  request: NextRequest,
  response: NextResponse
) {
  return createServerClient(
    process.env.NEXT_PUBLIC_SUPABASE_URL!,
    process.env.NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY!,
    {
      cookies: {
        getAll: () => request.cookies.getAll(),
        setAll: (list) =>
          list.forEach(({ name, value, options }) =>
            response.cookies.set(name, value, options)
          ),
      },
    }
  );
}

/**
 * Route Handler / Server Component 전용: Next.js `cookies()` 스토어를 받아
 * 서버용 Supabase 클라이언트를 만듭니다.
 */
export function createSupabaseServerClient(
  cookieStore: Awaited<ReturnType<typeof cookies>>
) {
  return createServerClient(
    process.env.NEXT_PUBLIC_SUPABASE_URL!,
    process.env.NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY!,
    {
      cookies: {
        getAll: () => cookieStore.getAll(),
        setAll: (list) =>
          list.forEach(({ name, value, options }) => {
            try {
              cookieStore.set(name, value, options)
            } catch {
              // Server Component에서 호출 시 쿠키 쓰기 불가 — 무시 (읽기는 정상 동작)
              // 실제 토큰 갱신은 middleware에서 처리됩니다
            }
          }),
      },
    }
  );
}

/**
 * Server Component에서 현재 로그인된 유저를 가져오는 헬퍼.
 * cookies()와 createSupabaseServerClient 반복 호출을 대신합니다.
 * @returns 로그인된 User 객체, 미로그인 시 null
 */
export async function getServerUser() {
  const cookieStore = await cookies();
  const supabase = createSupabaseServerClient(cookieStore);
  const { data: { user } } = await supabase.auth.getUser();
  return user;
}
</file>

<file path="src/lib/supabase/RPC_SPEC.md">
# Supabase RPC 명세서

> **프론트 → DB 담당자 전달용**  
> 이 파일에 정의된 RPC 함수들을 Supabase에 등록해 주세요.  
> 등록 완료된 항목은 ✅, 미등록은 ⏳로 표기합니다.

---

## 📋 전체 목록

| 상태 | RPC 함수명 | 파일 | 설명 |
|------|-----------|------|------|
| ⏳ | `get_or_create_ledger` | `rpc/ledger.ts` | 최신 ledger 조회, 없으면 자동 생성 |
| ⏳ | `get_my_ledgers` | `rpc/ledger.ts` | 유저의 전체 ledger 목록 |
| ⏳ | `create_ledger` | `rpc/ledger.ts` | 새 ledger 명시적 생성 |
| ⏳ | `get_canvas_widgets` | `rpc/canvas.ts` | ledger의 위젯 배치 목록 조회 |
| ⏳ | `replace_canvas_widgets` | `rpc/canvas.ts` | 위젯 배치 전체 교체 (트랜잭션) |

---

## 1. ledger 관련

### `get_or_create_ledger`

```sql
-- 인자
p_mem_id uuid  -- auth.users.id (tb_member.mem_id)

-- 반환: 단일 row
led_id   uuid
led_name text
```

**동작:**
1. `tb_ledger` WHERE `mem_id = p_mem_id` ORDER BY `regist_dt DESC` LIMIT 1
2. 결과 없으면 `led_name = '내 가계부'`로 INSERT 후 반환
3. RLS: 본인 것만 접근 가능

**호출처:** `useCanvasPersist.ts` (에디터 진입 시)

---

### `get_my_ledgers`

```sql
-- 인자
p_mem_id uuid

-- 반환: TABLE
led_id    uuid
led_name  text
regist_dt timestamptz
```

**동작:**
- `tb_ledger` WHERE `mem_id = p_mem_id` ORDER BY `regist_dt DESC`
- ledger 없으면 빈 배열 반환
- RLS: 본인 것만 조회 가능

**호출처:** `LoggedInView.tsx` (홈 화면 가계부 목록)

---

### `create_ledger`

```sql
-- 인자
p_mem_id   uuid
p_led_name text  -- 기본값 '내 가계부'

-- 반환: 단일 row
led_id uuid
```

**동작:**
- `tb_ledger` INSERT `(mem_id, led_name)` RETURNING `led_id`
- `get_or_create_ledger`와 달리 항상 새 row 생성 (기존 조회 없음)
- RLS: 본인 것만 생성 가능

**호출처:** 추후 "새 가계부 만들기" 기능

---

## 2. 캔버스(위젯 배치) 관련

### `get_canvas_widgets`

```sql
-- 인자
p_led_id uuid

-- 반환: TABLE
con_id   uuid
wid_type text    -- 프론트 WidgetType 값 (예: 'expense-memo')
position jsonb   -- { x, y, w, h, style }
```

**동작:**
```sql
SELECT wc.con_id, w.wid_type, wc.position
FROM tb_widget_config wc
JOIN tb_widget w ON w.wid_id = wc.wid_id
WHERE wc.led_id = p_led_id
```
- RLS: 본인 ledger만 조회 가능

**호출처:** `useCanvasPersist.ts` (에디터 진입 시 위젯 로드)

---

### `replace_canvas_widgets`

```sql
-- 인자
p_led_id  uuid
p_configs jsonb  -- 배열, 아래 구조

-- p_configs 항목 구조:
-- {
--   con_id:       uuid (string),
--   wid_type:     text,
--   position:     { x: int, y: int, w: int, h: int, style: object },
--   data_binding: {}
-- }

-- 반환: void
```

**동작 (트랜잭션 필수):**
1. `tb_widget_config` WHERE `led_id = p_led_id` DELETE (기존 전부 삭제)
2. `p_configs` 각 항목에 대해:
   - `tb_widget` WHERE `wid_type = p_configs[i].wid_type` → `wid_id` 조회
   - `tb_widget_config` INSERT `(con_id, led_id, wid_id, position, data_binding)`
3. 1~2 전체가 하나의 트랜잭션 (일부 실패 시 전체 rollback)
- RLS: 본인 ledger만 수정 가능

**호출처:** `useCanvasPersist.ts` (Ctrl+S / 저장 버튼)

---

## 3. position jsonb 구조

`tb_widget_config.position` 컬럼에 저장되는 JSON 형태:

```json
{
  "x": 0,
  "y": 0,
  "w": 4,
  "h": 3,
  "style": {
    "borderRadius": 12,
    "shadow": "md",
    "opacity": 1,
    "bgColor": "#FFFFFF",
    "textColor": "#111827"
  }
}
```

`style` 필드는 optional (없으면 프론트에서 기본값 적용).

---

## 4. wid_type 값 목록

`tb_widget` 마스터 데이터에 아래 `wid_type`이 등록되어 있어야 합니다:

| wid_type | 설명 |
|----------|------|
| `expense-memo` | 지출 메모 위젯 |
| `post-it` | 포스트잇 메모 위젯 |
| `quote` | 명언 위젯 |
| `flow-analysis` | 수입/지출 흐름 분석 |
| `portfolio-health` | 포트폴리오 건강도 |
| `monthly-expenses` | 월별 지출 차트 |
| `savings-goal` | 저축 목표 위젯 |

> **참고:** 프론트 `src/app/(main)/editor/_widgets/registry.ts`의 `WIDGET_REGISTRY`에서 최신 목록 확인 가능.
</file>

<file path="src/lib/supabase/rpc/auth.ts">
"use client";

// ─── rpc/auth.ts ──────────────────────────────────────────────────────────────
// Auth 관련 Supabase 함수 전체.
// Supabase Auth API 직접 호출 (별도 RPC 불필요).
//
// 포함 함수:
//   회원가입 플로우: sendSignupOtp → verifySignupOtp → updatePassword
//   로그인:         signInWithGoogle (OAuth), signIn (이메일)
//   세션:           getCurrentUser, getAuthSession, subscribeAuthState
//   로그아웃:       signOut

import { getSupabaseBrowserClient } from "../core/client";
import type { AuthChangeEvent, Session, User } from "@supabase/supabase-js";

// ── sendSignupOtp ─────────────────────────────────────────────────────────────
// Supabase Auth: signUp(email, tempPassword) → OTP 이메일 자동 발송
// @returns 에러 메시지 문자열, 성공 시 null

/**
 * 이메일로 회원가입을 시작합니다.
 * 임시 비밀번호로 계정을 생성하고 Supabase가 OTP 인증코드를 이메일로 발송합니다.
 * 인증 완료 후 updatePassword()로 실제 비밀번호를 설정해야 합니다.
 * @returns 에러 메시지 문자열, 성공 시 null
 */
export async function sendSignupOtp(email: string): Promise<string | null> {
  const supabase = getSupabaseBrowserClient();
  const tempPassword = crypto.randomUUID();
  const { error } = await supabase.auth.signUp({ email, password: tempPassword });

  if (error) {
    console.error("[rpc/auth] sendSignupOtp 실패:", error.message);
    return error.message;
  }
  return null;
}

// ── verifySignupOtp ───────────────────────────────────────────────────────────
// Supabase Auth: verifyOtp(email, token, type: 'signup')
// @returns 에러 메시지 문자열, 성공 시 null

/**
 * 이메일 OTP 인증코드를 검증합니다. (회원가입용)
 * @returns 에러 메시지 문자열, 성공 시 null
 */
export async function verifySignupOtp(
  email: string,
  token: string
): Promise<string | null> {
  const supabase = getSupabaseBrowserClient();
  const { error } = await supabase.auth.verifyOtp({
    email,
    token,
    type: "signup",
  });

  if (error) {
    console.error("[rpc/auth] verifySignupOtp 실패:", error.message);
    return "인증코드가 올바르지 않습니다.";
  }
  return null;
}

// ── updatePassword ────────────────────────────────────────────────────────────
// Supabase Auth: updateUser({ password })
// verifySignupOtp 성공 후 세션이 생긴 상태에서 호출해야 합니다.
// @returns 에러 메시지 문자열, 성공 시 null

/**
 * 인증 완료 후 실제 비밀번호를 설정합니다.
 * @returns 에러 메시지 문자열, 성공 시 null
 */
export async function updatePassword(password: string): Promise<string | null> {
  const supabase = getSupabaseBrowserClient();
  const { error } = await supabase.auth.updateUser({ password });

  if (error) {
    console.error("[rpc/auth] updatePassword 실패:", error.message);
    return error.message;
  }
  return null;
}

// ── signInWithGoogle ──────────────────────────────────────────────────────────
// Supabase Auth: signInWithOAuth({ provider: 'google' })
// Google 리디렉션 URL로 이동하므로 반환값 없음

/**
 * Google OAuth 로그인을 시작합니다.
 * Supabase가 Google 리디렉션 URL로 보내므로 반환값은 없습니다.
 * @param redirectTo 로그인 성공 후 돌아올 경로 (예: "/editor")
 */
export async function signInWithGoogle(redirectTo?: string): Promise<void> {
  const supabase = getSupabaseBrowserClient();
  await supabase.auth.signInWithOAuth({
    provider: "google",
    options: {
      redirectTo: `${window.location.origin}/auth/callback?next=${redirectTo ?? "/"}`,
    },
  });
}

// ── signIn ────────────────────────────────────────────────────────────────────
// Supabase Auth: signInWithPassword(email, password)
// @returns 성공 시 true, 실패 시 false

/**
 * 이메일/비밀번호로 로그인합니다.
 * @returns 성공 시 true, 실패 시 false
 */
export async function signIn(email: string, password: string): Promise<boolean> {
  const supabase = getSupabaseBrowserClient();
  const { error } = await supabase.auth.signInWithPassword({ email, password });
  return !error;
}

// ── signOut ───────────────────────────────────────────────────────────────────
// Supabase Auth: signOut()

/**
 * 로그아웃합니다.
 */
export async function signOut(): Promise<void> {
  const supabase = getSupabaseBrowserClient();
  await supabase.auth.signOut();
}

// ── getCurrentUser ────────────────────────────────────────────────────────────
// Supabase Auth: getUser()
// @returns User 객체 또는 미로그인 시 null

/**
 * 현재 로그인한 유저를 반환합니다.
 * @returns User 객체 또는 미로그인 시 null
 */
export async function getCurrentUser(): Promise<User | null> {
  const supabase = getSupabaseBrowserClient();
  const {
    data: { user },
  } = await supabase.auth.getUser();
  return user;
}

// ── getAuthSession ────────────────────────────────────────────────────────────
// Supabase Auth: getSession()
// @returns Session 객체 또는 없으면 null

/**
 * 현재 세션을 반환합니다.
 * @returns Session 객체 또는 없으면 null
 */
export async function getAuthSession(): Promise<Session | null> {
  const supabase = getSupabaseBrowserClient();
  const {
    data: { session },
  } = await supabase.auth.getSession();
  return session;
}

// ── subscribeAuthState ────────────────────────────────────────────────────────
// Supabase Auth: onAuthStateChange
// @returns unsubscribe 함수

/**
 * 인증 상태 변화(로그인/로그아웃/토큰 갱신)를 구독합니다.
 * @returns unsubscribe 함수
 */
export function subscribeAuthState(
  callback: (session: Session | null) => void
): () => void {
  const supabase = getSupabaseBrowserClient();
  const {
    data: { subscription },
  } = supabase.auth.onAuthStateChange(
    (_event: AuthChangeEvent, session: Session | null) => {
      callback(session);
    }
  );
  return () => subscription.unsubscribe();
}
</file>

