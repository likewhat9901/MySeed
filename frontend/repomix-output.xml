"use client";

// ─── rpc/canvas.ts ────────────────────────────────────────────────────────────
// 캔버스(위젯 배치) 관련 Supabase RPC 함수.
//
// RPC 목록:
//   get_canvas_widgets(p_led_id)              : ledger의 위젯 목록 조회
//   replace_canvas_widgets(p_led_id, p_configs): 위젯 상태 전체 교체 (트랜잭션)

import { getSupabaseBrowserClient } from "../core/client";
import type { WidgetItem } from "@/types/editor";
import { DEFAULT_WIDGET_STYLE } from "@/types/editor";
import type { WidgetPosition } from "../types/schema";

// ── get_canvas_widgets ────────────────────────────────────────────────────────
// RPC: get_canvas_widgets(p_led_id uuid)
// → TABLE(con_id uuid, wid_type text, position jsonb)

/**
 * 특정 ledger에 저장된 위젯 목록을 불러옵니다.
 * @returns WidgetItem 배열 (실패 시 빈 배열)
 */
export async function getCanvasWidgets(ledId: string): Promise<WidgetItem[]> {
  const supabase = getSupabaseBrowserClient()
  const { data, error } = await supabase.rpc('get_canvas_widgets', { p_led_id: ledId })

  if (error || !data) {
    console.error('[rpc/canvas] get_canvas_widgets 실패:', JSON.stringify(error))
    return []
  }

  return (data as { con_id: string; wid_type: string; position: unknown }[]).map(row => {
    const pos = row.position as WidgetPosition
    return {
      id:    row.con_id,
      type:  row.wid_type as WidgetItem['type'],
      x:     pos.x,
      y:     pos.y,
      w:     pos.w,
      h:     pos.h,
      style: pos.style ?? { ...DEFAULT_WIDGET_STYLE },
    }
  })
}

// ── replace_canvas_widgets ────────────────────────────────────────────────────
// RPC: replace_canvas_widgets(p_led_id uuid, p_configs jsonb) → void
// 내부: con_id 기준 UPSERT + 목록에 없는 기존 위젯 DELETE (트랜잭션)

/**
 * 현재 캔버스 위젯 상태를 DB에 저장합니다.
 * @returns 성공 시 true, 실패 시 false
 */
export async function saveCanvasWidgets(
  ledId: string,
  widgets: WidgetItem[],
): Promise<boolean> {
  const supabase = getSupabaseBrowserClient()
  const { error } = await supabase.rpc('replace_canvas_widgets', {
    p_led_id: ledId,
    p_configs: widgets.map(w => ({
      con_id:       w.id,
      wid_type:     w.type,
      position:     { x: w.x, y: w.y, w: w.w, h: w.h, style: w.style },
      data_binding: {},
    })),
  })

  if (error) {
    console.error('[rpc/canvas] replace_canvas_widgets 실패:', JSON.stringify(error))
    return false
  }

  return true
}
