'use client'

import { useState } from 'react'
import { ActiveTool } from '@/types/editor'
import { useEditorContext } from '../_context/EditorContext'

// ─── Types ───────────────────────────────────────────────────────────────────

interface SheetItem {
  id: string
  name: string
  isActive?: boolean  // 현재 열려 있는 시트 (초록색 강조)
}

interface FolderItem {
  id: string
  name: string
  icon: 'personal' | 'work' | 'shared'
  isOpen?: boolean    // 초기 펼침/접힘 상태 (FolderRow 로컬 state로 제어)
  sheets: SheetItem[]
}

interface LeftSidebarProps {
  isOpen: boolean          // 사이드바 펼침/접힘 (w-56 ↔ w-12)
  onToggle: () => void
}

// ─── Static Data ─────────────────────────────────────────────────────────────
// 현재 하드코딩된 더미 데이터. 추후 서버/DB 연동 예정

const FOLDERS: FolderItem[] = [
  {
    id: 'personal',
    name: 'Personal',
    icon: 'personal',
    isOpen: true,
    sheets: [
      { id: '1', name: '2024_Budget.seed', isActive: true },
      { id: '2', name: 'Savings_Goal.seed' },
    ],
  },
  {
    id: 'work',
    name: 'Work',
    icon: 'work',
    isOpen: false,
    sheets: [],
  },
  {
    id: 'shared',
    name: 'Shared',
    icon: 'shared',
    isOpen: false,
    sheets: [],
  },
]

const QUICK_ACTIONS: { icon: React.ReactNode; label: string; onClick?: () => void }[] = [
  { icon: <PlusIconSm />,  label: 'New Sheet'   },
  { icon: <SaveIcon />,   label: 'Save Draft'  },
  { icon: <ImportIcon />, label: 'Import Data' },
]

// ─── LeftSidebar ─────────────────────────────────────────────────────────────
// 왼쪽 사이드바. 펼침(w-56) / 접힘(w-12) 두 가지 레이아웃을 하나의 컴포넌트에서 처리.

// 도구 목록: 'select'만 활성화, 나머지는 opacity-50 + 준비 중 표시
const TOOLS: { id: ActiveTool; icon: React.ReactNode; label: string }[] = [
  { id: 'select', icon: <CursorIcon />,   label: 'Select'          },
  { id: 'text',   icon: <TextToolIcon />, label: 'Text (준비 중)'  },
  { id: 'edit',   icon: <ShapeIcon />,    label: 'Shape (준비 중)' },
  { id: 'grid',   icon: <ImageIcon />,    label: 'Image (준비 중)' },
]

export default function LeftSidebar({ isOpen, onToggle }: LeftSidebarProps) {
  const { activeTool, setActiveTool: onToolChange, saveCanvas, saveStatus } = useEditorContext()

  const isSaving = saveStatus === 'saving'
  const saveBtnLabel = isSaving ? 'Saving…' : saveStatus === 'saved' ? 'Saved ✓' : 'Save Draft'
  return (
    <aside
      className={`h-full bg-gray-50 border-r border-gray-200 flex flex-col shrink-0 select-none transition-all duration-200 overflow-hidden ${
        isOpen ? 'w-56' : 'w-12'
      }`}
    >
      {/* 사이드바 펼침/접힘 토글 버튼 */}
      <div className={`flex items-center h-10 shrink-0 border-b border-gray-200 ${isOpen ? 'justify-end px-2' : 'justify-center'}`}>
        <button
          onClick={onToggle}
          title={isOpen ? 'Collapse sidebar' : 'Expand sidebar'}
          className="w-7 h-7 flex items-center justify-center rounded-md text-gray-400 hover:bg-gray-100 hover:text-gray-600 transition-colors"
        >
          <ChevronSideIcon isOpen={isOpen} />
        </button>
      </div>

      {/* 접힌 상태: 아이콘만 세로로 나열 */}
      {!isOpen && (
        <div className="flex flex-col items-center gap-1 py-3 border-b border-gray-200">
          {TOOLS.map(tool => (
              <button
                key={tool.id}
                title={tool.label}
                onClick={() => onToolChange(tool.id)}
                className={`w-9 h-9 flex items-center justify-center rounded-lg transition-colors ${
                  activeTool === tool.id
                    ? 'bg-green-100 text-green-700'
                    : 'text-gray-400 hover:bg-gray-100 hover:text-gray-600'
                } ${tool.id !== 'select' ? 'opacity-50' : ''}`}
              >
              {tool.icon}
            </button>
          ))}
        </div>
      )}

      {/* 파일 탐색기 영역: 폴더 목록 */}
      <div className="flex-1 overflow-y-auto pt-3 px-1.5">
        {isOpen && (
          <p className="text-[10px] font-semibold text-gray-400 tracking-widest mb-2 px-1.5">
            EXPLORER
          </p>
        )}

        <div className="flex flex-col gap-0.5">
          {FOLDERS.map(folder => (
            isOpen
              // 펼친 상태: FolderRow (클릭으로 접기/펼치기 가능)
              ? <FolderRow key={folder.id} folder={folder} />
              // 접힌 상태: 폴더 아이콘만 표시
              : (
                <button
                  key={folder.id}
                  title={folder.name}
                  className="w-9 h-9 mx-auto flex items-center justify-center rounded-lg text-gray-500 hover:bg-gray-100 transition-colors"
                >
                  <FolderIcon type={folder.icon} />
                </button>
              )
          ))}
        </div>
      </div>

      {/* 하단 빠른 실행 버튼 — 전체 미구현 (disabled + opacity-50) */}
      <div className={`pt-3 pb-4 border-t border-gray-200 ${isOpen ? 'px-3' : 'px-1.5'}`}>
        {isOpen && (
          <p className="text-[10px] font-semibold text-gray-400 tracking-widest mb-2 px-1">
            QUICK ACTIONS
          </p>
        )}

        <div className={`flex flex-col ${isOpen ? 'gap-2' : 'gap-1 items-center'}`}>
          {isOpen ? (
            <>
              <button disabled title="준비 중" className="flex items-center gap-2 px-2 py-1.5 text-sm text-gray-400 rounded-lg opacity-50 cursor-not-allowed">
                <PlusIconSm />
                New Sheet
              </button>
              <button
                onClick={saveCanvas}
                disabled={isSaving}
                title="저장 (Ctrl+S)"
                className={`flex items-center justify-center gap-2 w-full px-3 py-2 text-white text-sm font-medium rounded-lg transition-colors ${
                  isSaving
                    ? 'bg-brand-dark opacity-60 cursor-not-allowed'
                    : saveStatus === 'saved'
                    ? 'bg-green-600 cursor-pointer'
                    : 'bg-brand-dark hover:bg-green-700 cursor-pointer'
                }`}
              >
                <SaveIcon />
                {saveBtnLabel}
              </button>
              <button disabled title="준비 중" className="flex items-center justify-center gap-2 w-full px-3 py-2 bg-white border border-gray-200 text-gray-700 text-sm font-medium rounded-lg opacity-50 cursor-not-allowed">
                <ImportIcon />
                Import Data
              </button>
            </>
          ) : (
            QUICK_ACTIONS.map(action => (
              <button
                key={action.label}
                disabled={action.label === 'Save Draft' ? isSaving : true}
                onClick={action.label === 'Save Draft' ? saveCanvas : undefined}
                title={action.label === 'Save Draft' ? `저장 (Ctrl+S)` : `${action.label} (준비 중)`}
                className={`w-9 h-9 flex items-center justify-center rounded-lg transition-colors ${
                  action.label === 'Save Draft'
                    ? isSaving
                      ? 'text-gray-400 opacity-60 cursor-not-allowed'
                      : saveStatus === 'saved'
                      ? 'text-green-600 hover:bg-green-50'
                      : 'text-brand-dark hover:bg-green-50'
                    : 'text-gray-400 opacity-50 cursor-not-allowed'
                }`}
              >
                {action.icon}
              </button>
            ))
          )}
        </div>
      </div>
    </aside>
  )
}

// ─── Folder Row ───────────────────────────────────────────────────────────────
// 개별 폴더 행. 클릭으로 시트 목록을 접기/펼치는 로컬 state 보유.

function FolderRow({ folder }: { folder: FolderItem }) {
  // isOpen을 로컬 state로 관리해 각 폴더가 독립적으로 접기/펼치기 가능
  const [isOpen, setIsOpen] = useState(folder.isOpen ?? false)

  return (
    <div>
      <button
        onClick={() => setIsOpen(v => !v)}
        className="flex items-center gap-2 w-full px-1 py-1.5 text-sm text-gray-700 hover:bg-gray-100 rounded-lg transition-colors"
      >
        <ChevronIcon isOpen={isOpen} />
        <FolderIcon type={folder.icon} />
        <span className="font-medium truncate">{folder.name}</span>
      </button>

      {/* 펼쳐졌을 때만 시트 목록 표시 */}
      {isOpen && folder.sheets.length > 0 && (
        <div className="ml-5 mt-0.5 flex flex-col gap-0.5">
          {folder.sheets.map(sheet => (
            <SheetRow key={sheet.id} sheet={sheet} />
          ))}
        </div>
      )}
    </div>
  )
}

// ─── Sheet Row ────────────────────────────────────────────────────────────────
// 개별 시트 항목. isActive이면 초록색 강조 표시.
// 현재 클릭 이벤트 없음 — 추후 시트 전환 기능 연결 예정

function SheetRow({ sheet }: { sheet: SheetItem }) {
  return (
    <button
      className={`flex items-center gap-2 w-full px-2 py-1.5 text-sm rounded-lg transition-colors ${
        sheet.isActive
          ? 'bg-green-50 text-brand-dark font-medium'
          : 'text-gray-600 hover:bg-gray-100'
      }`}
    >
      <SheetIcon isActive={sheet.isActive} />
      <span className="truncate">{sheet.name}</span>
    </button>
  )
}

// ─── Icons ────────────────────────────────────────────────────────────────────

function ChevronSideIcon({ isOpen }: { isOpen: boolean }) {
  return (
    <svg
      width="14"
      height="14"
      viewBox="0 0 24 24"
