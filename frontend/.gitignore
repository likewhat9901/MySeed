# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── 의존성 ────────────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── 테스트 ────────────────────────────────────────────────────────────────────
/coverage

# ── Next.js 빌드 산출물 ────────────────────────────────────────────────────────
/.next/
/out/
/build

# ── 환경변수 (절대 커밋 금지) ──────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── 로그 ─────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Supabase ─────────────────────────────────────────────────────────────────
/supabase/.temp

# ── 배포 플랫폼 ───────────────────────────────────────────────────────────────
.vercel
.railway

# ── 인증서 ────────────────────────────────────────────────────────────────────
*.pem
*.key
*.cert
